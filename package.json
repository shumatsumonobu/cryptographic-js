{
  "name": "cryptographic-js",
  "version": "1.0.3",
  "description": "Lightweight AES encryption and decryption for Node.js",
  "_moduleAliases": {
    "~": "."
  },
  "main": "dist/build.common.js",
  "module": "dist/build.esm.js",
  "types": "types/index.d.ts",
  "scripts": {
    "watch": "rollup -c --watch",
    "prewatch": "rm -rf dist types",
    "build": "rollup -c",
    "prebuild": "rm -rf dist types",
    "test": "jest",
    "start": "ts-node -r tsconfig-paths/register -P tsconfig.json -O '{\"module\":\"commonjs\"}' -e \"import * as index from '~/index';console.log(index);\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shumatsumonobu/cryptographic-js.git"
  },
  "files": [
    "dist/*.js",
    "types/*.d.ts",
    "package.json"
  ],
  "keywords": [
    "aes",
    "crypto",
    "cipher",
    "encryption",
    "decryption",
    "cbc",
    "ctr",
    "cfb",
    "node",
    "typescript"
  ],
  "author": "shumatsumonobu <shumatsumonobu@gmail.com> (https://x.com/shumatsumonobu)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shumatsumonobu/cryptographic-js/issues",
    "email": "shumatsumonobu@gmail.com"
  },
  "homepage": "https://github.com/shumatsumonobu/cryptographic-js#readme",
  "dependencies": {
    "crypto-random-string": "^3.3.0",
    "module-alias": "^2.2.2",
    "moment": "^2.26.0",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/jest": "^26.0.3",
    "@types/node": "^14.14.10",
    "builtin-modules": "^3.1.0",
    "jest": "^26.1.0",
    "rollup": "^2.21.0",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-json": "^4.0.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-terser": "^6.1.0",
    "rollup-plugin-typescript2": "^0.27.1",
    "ts-loader": "^7.0.5",
    "ts-node": "^8.10.2",
    "tsconfig-paths": "^3.9.0",
    "tslint": "^6.1.2",
    "typescript": "^3.9.5"
  }
}